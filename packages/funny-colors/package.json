{
  "name": "funny-colors",
  "version": "0.0.0",
  "description": "Plugin-based procedural background generation system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "funny-colors": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@funny-colors/core": "workspace:*",
    "@funny-colors/nodes": "workspace:*",
    "@funny-colors/renderer": "workspace:*"
  },
  "devDependencies": {
    "@funny-colors/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "procedural",
    "background",
    "webgl",
    "node-graph",
    "generative-art"
  ],
  "license": "MIT"
}
